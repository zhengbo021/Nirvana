{
	"compilerOptions": {
		"module": "Node16",
		"target": "ES2022",
		"outDir": "out",
		"lib": [
			"ES2022"
		],
		"sourceMap": true,
		"rootDir": "./",
		"strict": true,
		"skipLibCheck": true,
		"types": [
			"node",
			"mocha"
		]
	},
	"include": [
		"src/**/*",
	],
	"ts-node": {
		"transpileOnly": false
	}
}